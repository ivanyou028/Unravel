# Agora
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=           # From Agora Console > Account Settings > RESTful API
AGORA_CUSTOMER_SECRET=       # From Agora Console > Account Settings > RESTful API

# Anthropic (LLM)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514    # or claude-haiku-4-5-20251001 for faster/cheaper

# TTS — pick one vendor and fill in its keys
TTS_VENDOR=microsoft         # or "elevenlabs"

# Microsoft Azure TTS
MICROSOFT_TTS_KEY=
MICROSOFT_TTS_REGION=eastus
MICROSOFT_TTS_VOICE=en-US-AndrewMultilingualNeural

# ElevenLabs TTS (alternative)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Client-side (prefix with VITE_ for Vite)
VITE_AGORA_APP_ID=
VITE_API_BASE=http://localhost:3001
